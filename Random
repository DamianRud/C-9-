ИГРА УГАДАЙ ЧИСЛО С ДИОПОЗОНОМ
using System;

namespace C__за_9_часов
{
    internal class Class1
    {
        static void Main(string[] args)
        {
            int number;
            int lower, higher;
            int triesCount = 5;
            int user;
            Random random = new Random();

            number = random.Next(0, 101);

            // Гарантируем корректные границы
            lower = Math.Max(0, number - 10);
            higher = Math.Min(100, number + 10);

            Console.WriteLine("Мы загадали число от 0 до 100.");
            Console.WriteLine("Оно больше чем " + lower + ", но меньше чем " + higher + ".");
            Console.WriteLine("Что это за число? У вас " + triesCount + " попыток отгадать.");

            while (triesCount > 0)
            {
                Console.WriteLine("Ваш ответ:");

                if (int.TryParse(Console.ReadLine(), out user))
                {
                    if (user == number)
                    {
                        Console.WriteLine("Вы правы! Это было число " + number);
                        break;
                    }
                    else
                    {
                        triesCount--;
                        Console.WriteLine("Вы не угадали. Осталось попыток: " + triesCount);
                    }
                }
                else
                {
                    Console.WriteLine("Введите корректное число!");
                }
            }

            if (triesCount == 0)
            {
                Console.WriteLine("Попытки закончились. Было загадано число " + number);
            }
        }
    }
}






