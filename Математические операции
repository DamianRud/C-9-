    internal class Class1
    {
        static void Main(string[] args)
        {
            int timeInMinutes = 130;
            int hour;
            int minute;

            hour = timeInMinutes / 60;
            minute = timeInMinutes % 60;

            Console.WriteLine("Hours" + hour);
            Console.WriteLine("minutes" + minute);
        }
    }
}
