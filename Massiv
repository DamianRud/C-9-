НАХОЖДЕНИЕ СУММЫ ЭЛЕМЕНТА
using System;

namespace C__за_9_часов
{
    internal class Class1
    {
        static void Main(string[] args)
        {
            int[] array = { 2, 3, 4, 7, 8 };// Инициализация массива
            int sum=0;// Инициализация переменной для хранения суммы элементов массива

            for (int i = 0; i < array.Length; i++)// Цикл для вывода элементов массива
            {
                sum+=array[i];// Суммирование элементов массива
            }
            {
                Console.WriteLine(sum);// Вывод суммы элементов массива на экран
            }
        }
    }
}








НАХОЖДЕНИЕ МАКСИМАЛЬНОГО ЭЛЕМЕНТА
using System;

namespace C__за_9_часов
{
    internal class Class1
    {
        static void Main(string[] args)
        {
            int[] array = { 1, 3, 5, 8, 12, 2, 25 };// Пример массива
            int maxElement = int.MinValue;// Инициализируем максимальный элемент минимальным значением

            for (int i = 0; i < array.Length; i++)// Проходим по каждому элементу массива
            {
                if (maxElement < array[i])// Если текущий элемент больше максимального, обновляем максимальный элемент
                {
                    maxElement = array[i];// Обновляем максимальный элемент
                }
            }

            Console.WriteLine("Максимальный элемент: " + maxElement);// Выводим максимальный элемент на консоль
        }
    }
}
















