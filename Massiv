                        line = Convert.ToInt32(Console.ReadLine())-1;
                        Console.WriteLine("введите номер столбца");
                        column = Convert.ToInt32(Console.ReadLine())-1;
                        Console.WriteLine("Этот автор;" + books[line,column]);
                        break;
                    case 2:
                        string author;
                        bool authorFound = false;
                        Console.WriteLine("Введите автора");
                        author = Console.ReadLine();
                        for(int i = 0; i < books.GetLength(0); i++)
                        {
                            for(int j = 0; j < books.GetLength(1); j++)
                            {
                                if (books[i, j].ToLower() == author.ToLower())
                                {
                                    Console.WriteLine("Книга этого автора находится на полке " + (i + 1) + " в столбце " + (j + 1));
                                    authorFound = true;
                                }
                            }
                                if(authorFound==false)
                            {
                                Console.WriteLine("Такого автора нет в библиотеке");
                            }
                        }
                        break;
                    case 3:
                        isOpen = false;
                        break;
                    default:
                        Console.WriteLine("Введина не верная команда");
                        break;


                        {
                            if (isOpen)
                            {
                                Console.WriteLine("Выберите пунтк меню:");
                            }
                        }




                        Console.ReadKey();
                        Console.Clear();

                }

